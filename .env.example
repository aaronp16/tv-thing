# book-thing environment configuration
# Copy to .env and customize as needed

# MyAnonamouse session cookie (required)
# Get this from MAM Settings -> Security -> Generate Session Key
MAM_ID=your_mam_session_key_here

# MyAnonamouse user ID (required)
# Found in your MAM profile URL: myanonamouse.net/u/{UID}
MAM_UID=123456

# Book download directory (for library scanning)
# In Docker, this is also the Calibre-Web library directory
BOOKS_DIR=./books

# qBittorrent WebUI URL (required)
QB_URL=http://localhost:8080

# qBittorrent WebUI credentials
QB_USERNAME=admin
QB_PASSWORD=your_qbittorrent_password

# Category to use for book downloads in qBittorrent
# This category will be auto-created if it doesn't exist
QB_CATEGORY=books

# Save path in qBittorrent (optional, uses category default if not set)
# QB_SAVE_PATH=/downloads/books

# Calibre-Web integration (optional — leave empty to disable)
# When set, completed downloads are automatically registered in Calibre-Web's database
# Requires: Admin → Edit Basic Configuration → Enable Uploads ✓
#           Admin → Edit User → Upload permission ✓
CALIBRE_WEB_URL=http://calibre-web:8083
CALIBRE_WEB_USERNAME=admin
CALIBRE_WEB_PASSWORD=your_calibre_web_password
